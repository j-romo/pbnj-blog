---
// ./src/components/PortableTextImage.astro
import { urlForImage } from "../sanity/lib/url-for-image";

// The image data is in node, not value
const { node, isInline } = Astro.props;

if (!node || !node.asset) {
  console.error("PortableTextImage missing asset:", Astro.props);
  return "";
}

// Extract properties from node
const { asset, alt, caption, alignment = 'center', size = 'medium' } = node;

// Get the image URL - node.asset already has a URL
const url = asset.url || urlForImage(asset).url();
---

<figure class={`image ${alignment} ${size}`}>
  <img 
    src={url} 
    alt={alt || ''} 
    class={`responsive__img ${isInline ? 'inline' : 'block'}`}
    loading="lazy" 
  />
  {caption && <figcaption>{caption}</figcaption>}
</figure>
{(alignment === 'left' || alignment === 'right') && <div class="clearfix"></div>}

<style>
  figure.image {
    margin: 2rem 0;
  }
  
  figure.image img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }
  
  figure.image figcaption {
    font-size: 0.9rem;
    color: #666;
    margin-top: 0.5rem;
    text-align: center;
  }
  
  /* Alignment */
  .image.center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }
  
  .image.left {
    float: left;
    margin-right: 2rem;
    margin-left: 0;
  }
  
  .image.right {
    float: right;
    margin-left: 2rem;
    margin-right: 0;
  }

  /* Size controls */
  .image.small {
    max-width: 40%;
  }

  .image.medium {
    max-width: 70%;
  }

  .image.large {
    max-width: 100%;
  }

  /* Adjust float widths for smaller sizes */
  .image.left.small,
  .image.right.small {
    max-width: 40%;
  }

  .image.left.medium,
  .image.right.medium {
    max-width: 55%;
  }

  /* Mobile responsiveness */
  @media (max-width: 768px) {
    .image.left,
    .image.right {
      float: none;
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* Clearfix for floated images */
  .clearfix {
    clear: both;
    height: 0;
    margin: 0;
    padding: 0;
  }
</style>
