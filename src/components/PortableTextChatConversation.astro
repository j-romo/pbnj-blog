---
const { node } = Astro.props;

if (!node || !node.messages) {
  console.error("PortableTextChatConversation missing messages:", Astro.props);
  return null;
}

const { messages, style = 'modern' } = node;
---

<div class={`chat-conversation chat-${style}`}>
  {messages.map((message: any) => {
    const { text, sender, side = 'right', timestamp } = message;
    
    return (
      <div class={`chat-message-wrapper ${side}`}>
        {sender && side === 'left' && (
          <div class="chat-sender-name">{sender}</div>
        )}
        <div class={`chat-bubble ${side}`}>
          <div class="chat-text">{text}</div>
          {timestamp && (
            <div class="chat-timestamp">{timestamp}</div>
          )}
        </div>
        {sender && side === 'right' && (
          <div class="chat-sender-name right">{sender}</div>
        )}
      </div>
    );
  })}
</div>

<style>
  .chat-conversation {
    margin: 2rem 0;
    padding: 1.5rem;
    background: #f9fafb;
    border-radius: 12px;
    max-width: 100%;
  }

  .chat-message-wrapper {
    display: flex;
    flex-direction: column;
    margin-bottom: 1rem;
  }

  .chat-message-wrapper:last-child {
    margin-bottom: 0;
  }

  .chat-message-wrapper.left {
    align-items: flex-start;
  }

  .chat-message-wrapper.right {
    align-items: flex-end;
  }

  .chat-sender-name {
    font-size: 0.75rem;
    font-weight: 600;
    color: #6b7280;
    margin-bottom: 0.25rem;
    margin-left: 0.75rem;
  }

  .chat-sender-name.right {
    margin-left: 0;
    margin-right: 0.75rem;
  }

  .chat-bubble {
    max-width: 75%;
    padding: 0.75rem 1rem;
    border-radius: 18px;
    position: relative;
    word-wrap: break-word;
  }

  /* Modern style (iMessage-like) */
  .chat-modern .chat-bubble.left {
    background: #e5e7eb;
    color: #111827;
    border-bottom-left-radius: 4px;
  }

  .chat-modern .chat-bubble.right {
    background: #3b82f6;
    color: white;
    border-bottom-right-radius: 4px;
  }

  /* Classic style (WhatsApp-like) */
  .chat-classic .chat-bubble.left {
    background: white;
    color: #111827;
    border: 1px solid #e5e7eb;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }

  .chat-classic .chat-bubble.right {
    background: #dcf8c6;
    color: #111827;
    border: 1px solid #c3e6a8;
  }

  /* Minimal style */
  .chat-minimal .chat-bubble.left {
    background: transparent;
    color: #111827;
    border-left: 3px solid #9ca3af;
    border-radius: 0;
    padding-left: 1rem;
  }

  .chat-minimal .chat-bubble.right {
    background: transparent;
    color: #111827;
    border-right: 3px solid #3b82f6;
    border-radius: 0;
    padding-right: 1rem;
  }

  .chat-text {
    font-size: 0.95rem;
    line-height: 1.5;
    white-space: pre-wrap;
  }

  .chat-timestamp {
    font-size: 0.7rem;
    margin-top: 0.35rem;
    opacity: 0.7;
  }

  .chat-modern .chat-bubble.right .chat-timestamp {
    color: rgba(255, 255, 255, 0.9);
  }

  .chat-classic .chat-bubble .chat-timestamp,
  .chat-minimal .chat-bubble .chat-timestamp {
    color: #6b7280;
  }

  /* Mobile responsiveness */
  @media (max-width: 768px) {
    .chat-conversation {
      padding: 1rem;
      margin: 1.5rem 0;
    }

    .chat-bubble {
      max-width: 85%;
      padding: 0.65rem 0.85rem;
      font-size: 0.9rem;
    }

    .chat-sender-name {
      font-size: 0.7rem;
      margin-left: 0.5rem;
    }

    .chat-sender-name.right {
      margin-right: 0.5rem;
    }
  }

  /* Dark mode support (optional) */
  @media (prefers-color-scheme: dark) {
    .chat-conversation {
      background: #1f2937;
    }

    .chat-modern .chat-bubble.left {
      background: #374151;
      color: #f3f4f6;
    }

    .chat-classic .chat-bubble.left {
      background: #374151;
      color: #f3f4f6;
      border-color: #4b5563;
    }

    .chat-minimal .chat-bubble.left,
    .chat-minimal .chat-bubble.right {
      color: #f3f4f6;
    }
  }
</style>
